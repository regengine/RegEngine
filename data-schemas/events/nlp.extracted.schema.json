{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "NLP Extracted Event",
    "type": "object",
    "properties": {
        "event_id": {
            "type": "string"
        },
        "document_id": {
            "type": "string"
        },
        "tenant_id": {
            "type": [
                "string",
                "null"
            ]
        },
        "source_url": {
            "type": "string"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "entities": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string"
                    },
                    "text": {
                        "type": "string"
                    },
                    "start": {
                        "type": "integer"
                    },
                    "end": {
                        "type": "integer"
                    },
                    "attrs": {
                        "type": "object"
                    }
                },
                "required": [
                    "type",
                    "text",
                    "start",
                    "end"
                ]
            }
        }
    },
    "required": [
        "event_id",
        "document_id",
        "timestamp",
        "entities"
    ]
}