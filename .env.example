# RegEngine Environment Configuration
# Copy to .env and fill in values (DO NOT commit .env to git)

# AWS (LocalStack for dev, real credentials for prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Neo4j - CHANGE IN PRODUCTION
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=  # Required: set a strong password

# Admin API - CHANGE IN PRODUCTION
ADMIN_MASTER_KEY=  # Required: generate with `openssl rand -hex 32`

# Kafka
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Database
DATABASE_URL=postgresql://regengine:regengine@postgres:5432/regengine

# Redis
REDIS_URL=redis://redis:6379

# Security (DO NOT SET IN PRODUCTION)
# AUTH_TEST_BYPASS_TOKEN=  # Only for local development
