# =============================================================================
# RegEngine — Environment Variable Template (#533)
# =============================================================================
# 1. Copy to .env:   cp .env.example .env
# 2. Fill in EVERY value marked REPLACE_ME — leave NO placeholder in .env
# 3. NEVER commit .env to version control (it is .gitignored via .env.*)
#
# Generate strong secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#   openssl rand -base64 48
#
# Run startup validation: python scripts/validate_env.py
# =============================================================================
# RegEngine Environment Configuration
# Copy to .env and fill in values (DO NOT commit .env to git)

# --- Runtime Mode ---
# CRITICAL: Auth bypass tokens are ONLY honored when set to "development" or "test".
# Defaults to "production" (bypass disabled) when unset.
REGENGINE_ENV=development

# --- Feature Flags ---
# Enable PCOS (Production Compliance OS) vertical — disabled by default
ENABLE_PCOS=false

# Object storage (MinIO for dev, S3-compatible service for prod)
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000

# Neo4j — Legacy: being migrated to PostgreSQL (recursive CTEs replace graph queries)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=  # Required: set a strong password

# Admin API - CHANGE IN PRODUCTION
ADMIN_MASTER_KEY=  # Required: generate with `openssl rand -hex 32`

# JWT signing key — MUST match between admin service (Railway) and frontend (Vercel)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET_KEY=  # Required
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=7

# Kafka — Legacy: being migrated to PostgreSQL (pg_notify replaces message bus)
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Database (POSTGRES_PASSWORD is required — no default in production)
# Generate a strong password: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://regengine:<password>@postgres:5432/regengine
# Admin service uses async psycopg driver — set if different from DATABASE_URL
ADMIN_DATABASE_URL=postgresql+psycopg://regengine:<password>@postgres:5432/regengine_admin
# PCOS payroll vertical database (shares regengine_admin schema by default)
ENTERTAINMENT_DATABASE_URL=postgresql+psycopg://regengine:<password>@postgres:5432/regengine_admin

# Redis — Legacy: being migrated to PostgreSQL (RLS + connection pooling replace cache layer)
REDIS_URL=redis://redis:6379

# Service-to-service trust (REGENGINE_INTERNAL_SECRET)
# Shared secret for internal service calls that set X-RegEngine-Tenant-ID.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
REGENGINE_INTERNAL_SECRET=

# Single service-account API key (optional — for non-user API callers)
# Both must be set together; TENANT_ID must be a valid UUID.
REGENGINE_API_KEY=
REGENGINE_API_KEY_TENANT_ID=

# Test bypass (local development ONLY — never set in staging or production)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# AUTH_TEST_BYPASS_TOKEN=
# AUTH_TEST_BYPASS_TENANT_ID=  # UUID of the tenant the bypass key maps to

# Scheduler (required — no default)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SCHEDULER_API_KEY=

# Monitoring stack (docker-compose.monitoring.yml)
GRAFANA_PASSWORD=  # Required when running monitoring stack
GRAFANA_ADMIN_USER=admin

# Prometheus metrics auth — protects /metrics endpoints
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
METRICS_API_KEY=

# Auth fallthrough control — in production, Supabase auth failure is fatal by default.
# Set to "true" ONLY if you need local JWT fallback in a production environment.
# ALLOW_LOCAL_JWT_FALLBACK=false

# Internal service-to-service secret (used by security tests and inter-service calls)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_SECRET=

# CORS — comma-separated allowed origins (used by shared/cors.py)
# Local dev: http://localhost:3000,https://regengine.co
CORS_ALLOWED_ORIGINS=https://regengine.co,https://www.regengine.co,https://app.regengine.co

# AI & LLM (optional — enables global mapping engine)
# Valid Groq models: llama3-70b-8192, llama3-8b-8192, mixtral-8x7b-32768
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
OPENAI_API_KEY=

# Global Regulatory Discovery
REGULATORY_DISCOVERY_INTERVAL=24  # Nightly sync interval in hours
REGULATORY_POLITE_DELAY=2         # Delay between scraper requests (seconds)

# OAuth / OIDC (optional — for external IdP integration)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=
# OAUTH_ISSUER=

# -----------------------------------------------------------------------------
# Supabase (Auth + realtime DB)
# -----------------------------------------------------------------------------
# Frontend (Next.js) uses the NEXT_PUBLIC_ prefix; backend services use the plain names.
# Set ALL FOUR so both frontend and backend services pick up the correct values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co          # Same value — used by backend services (admin, etc.)
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # Public anon key — safe to expose in client
SUPABASE_ANON_KEY=              # Same value — plain-name alias for backend services
SUPABASE_SERVICE_ROLE_KEY=      # Required for server-side admin operations — KEEP SECRET. Never expose to browser.

# -----------------------------------------------------------------------------
# MinIO (object storage — dev only, use S3/R2 in production)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=  # Required: set explicitly (default 'minioadmin' is a known exploit target)
MINIO_ROOT_PASSWORD=  # Required: set explicitly (default 'minioadmin123' is a known exploit target)

# -----------------------------------------------------------------------------
# Frontend / Next.js
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8400
# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Vercel (set in Vercel project settings, NOT locally)
# These are referenced as @secret-name in vercel.json (#544):
#   vercel secrets add ingestion-service-url  https://your.railway.app
#   vercel secrets add compliance-service-url https://your.railway.app
#   vercel secrets add admin-service-url      https://your.railway.app
# -----------------------------------------------------------------------------
# INGESTION_SERVICE_URL=https://your-ingestion-service.up.railway.app
# COMPLIANCE_SERVICE_URL=https://your-compliance-service.up.railway.app
# ADMIN_SERVICE_URL=https://your-admin-service.up.railway.app
