# RegEngine Environment Configuration
# Copy to .env and fill in values (DO NOT commit .env to git)

# --- Runtime Mode ---
# CRITICAL: Auth bypass tokens are ONLY honored when set to "development" or "test".
# Defaults to "production" (bypass disabled) when unset.
REGENGINE_ENV=development

# --- Feature Flags ---
# Enable PCOS (Production Compliance OS) vertical — disabled by default
ENABLE_PCOS=false

# Object storage (MinIO for dev, S3-compatible service for prod)
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000

# Neo4j - CHANGE IN PRODUCTION
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=  # Required: set a strong password

# Admin API - CHANGE IN PRODUCTION
ADMIN_MASTER_KEY=  # Required: generate with `openssl rand -hex 32`

# Kafka
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Database (POSTGRES_PASSWORD is required — no default in production)
# Generate a strong password: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://regengine:<password>@postgres:5432/regengine

# Redis
REDIS_URL=redis://redis:6379

# Service-to-service trust (REGENGINE_INTERNAL_SECRET)
# Shared secret for internal service calls that set X-RegEngine-Tenant-ID.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
REGENGINE_INTERNAL_SECRET=

# Single service-account API key (optional — for non-user API callers)
# Both must be set together; TENANT_ID must be a valid UUID.
REGENGINE_API_KEY=
REGENGINE_API_KEY_TENANT_ID=

# Test bypass (local development ONLY — never set in staging or production)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# AUTH_TEST_BYPASS_TOKEN=
# AUTH_TEST_BYPASS_TENANT_ID=  # UUID of the tenant the bypass key maps to

# Scheduler (required — no default)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SCHEDULER_API_KEY=

# Monitoring stack (docker-compose.monitoring.yml)
GRAFANA_PASSWORD=  # Required when running monitoring stack
GRAFANA_ADMIN_USER=admin

# AI & LLM (optional — enables global mapping engine)
# Valid Groq models: llama3-70b-8192, llama3-8b-8192, mixtral-8x7b-32768
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
OPENAI_API_KEY=

# Global Regulatory Discovery
REGULATORY_DISCOVERY_INTERVAL=24  # Nightly sync interval in hours
REGULATORY_POLITE_DELAY=2         # Delay between scraper requests (seconds)

# OAuth / OIDC (optional — for external IdP integration)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=
# OAUTH_ISSUER=
