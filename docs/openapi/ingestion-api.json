        "/scrape/{adaptor}": {
            "post": {
                "summary": "Scrape Registry",
                "description": "Run a state registry adaptor and enqueue normalized events.\n\nPlaceholder implementation: lists sources and returns their metadata without network fetch.",
                "operationId": "scrape_registry_scrape__adaptor__post",
                "parameters": [
                    {
                        "name": "adaptor",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Adaptor"
                        }
                    },
                    {
                        "name": "X-RegEngine-API-Key",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "title": "X-Regengine-Api-Key"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "title": "Response Scrape Registry Scrape  Adaptor  Post"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/ingest/url": {
            "post": {
                "summary": "Ingest Url",
                "description": "Fetch content from the given URL, normalize it, and emit an event.\n\nArgs:\n    payload: Ingestion request with URL and source system\n    api_key: Validated API key (includes tenant_id)\n\nReturns:\n    Normalized event with tenant_id for multi-tenant routing",
                "operationId": "ingest_url_ingest_url_post",
                "parameters": [
                    {
                        "name": "X-RegEngine-API-Key",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "title": "X-Regengine-Api-Key"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/IngestRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NormalizedEvent"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
