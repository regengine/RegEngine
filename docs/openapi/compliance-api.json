        "/validate": {
            "post": {
                "summary": "Validate Compliance",
                "description": "Validate customer configuration against a compliance checklist\n\n**Returns yes/no pass/fail status with line-item results**\n\nRequest body:\n```json\n{\n  \"checklist_id\": \"hipaa_compliance\",\n  \"customer_config\": {\n    \"hipaa_001\": true,\n    \"hipaa_002\": true,\n    \"hipaa_003\": false\n  }\n}\n```\n\nResponse:\n```json\n{\n  \"overall_status\": \"FAIL\",\n  \"pass_rate\": 0.67,\n  \"items\": [\n    {\n      \"requirement_id\": \"hipaa_001\",\n      \"requirement\": \"Encrypt PHI at rest\",\n      \"status\": \"PASS\",\n      \"evidence\": \"Requirement met\"\n    },\n    {\n      \"requirement_id\": \"hipaa_003\",\n      \"requirement\": \"Role-Based Access Control\",\n      \"status\": \"FAIL\",\n      \"evidence\": \"Requirement not met\",\n      \"remediation\": \"Implement RBAC system...\"\n    }\n  ],\n  \"next_steps\": [\n    \"Address failed requirements before launching\",\n    \"\u2192 Implement RBAC for PHI access\"\n  ]\n}\n```",
                "operationId": "validate_compliance_validate_post",
                "parameters": [
                    {
                        "name": "X-RegEngine-API-Key",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "title": "X-Regengine-Api-Key"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ValidationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
