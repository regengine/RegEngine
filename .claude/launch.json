{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && export NEXT_PUBLIC_API_BASE_URL=http://localhost:8400 && cd frontend && npm run dev"],
      "port": 3000
    },
    {
      "name": "admin-api",
      "runtimeExecutable": "env",
      "runtimeArgs": ["ADMIN_MASTER_KEY=dev-master-key", "AUTH_SECRET_KEY=dev-secret-key-for-local-only", "REGENGINE_ENV=development", "python3", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8400"],
      "port": 8400,
      "cwd": "services/admin"
    },
    {
      "name": "ingestion-service",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "nlp-service",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8100"],
      "port": 8100
    },
    {
      "name": "graph-service",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8200"],
      "port": 8200
    },
    {
      "name": "compliance-api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8500"],
      "port": 8500
    },
    {
      "name": "scheduler",
      "runtimeExecutable": "python",
      "runtimeArgs": ["main.py"],
      "port": 8600
    }
  ]
}
