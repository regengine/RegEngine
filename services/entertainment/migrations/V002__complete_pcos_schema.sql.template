-- V002: Complete PCOS Schema Migration
-- 
-- Replaces partial PCOS schema (9 tables) with complete schema (38 tables)
-- from Admin DB. This completes the Entertainment vertical data isolation.
--
-- Context:
-- - V001 created 9 PCOS tables (incomplete)
-- - Admin DB has 38 PCOS tables (complete)
-- - This migration brings full schema to Entertainment DB
-- - Enables removal of PCOS from Admin DB (V27)

-- ============================================================================
-- PHASE 1: Drop existing partial schema
-- ============================================================================

DROP TABLE IF EXISTS pcos_tasks CASCADE;
DROP TABLE IF EXISTS pcos_projects CASCADE;
DROP TABLE IF EXISTS pcos_people CASCADE;
DROP TABLE IF EXISTS pcos_insurance_policies CASCADE;
DROP TABLE IF EXISTS pcos_evidence CASCADE;
DROP TABLE IF EXISTS pcos_engagements CASCADE;
DROP TABLE IF EXISTS pcos_compliance_snapshots CASCADE;
DROP TABLE IF EXISTS pcos_company_registrations CASCADE;
DROP TABLE IF EXISTS pcos_companies CASCADE;

-- ============================================================================
-- PHASE 2: Create complete PCOS schema (38 tables from Admin DB)
-- ============================================================================

--
-- Name: pcos_abc_questionnaire_responses; Type: TABLE
--

CREATE TABLE public.pcos_abc_questionnaire_responses (
    id uuid NOT NULL,
    tenant_id uuid NOT NULL,
    analysis_id uuid NOT NULL,
    question_code character varying(50) NOT NULL,
    question_text text NOT NULL,
    question_category character varying(50) NOT NULL,
    response_value character varying(50),
    response_details text,
    response_weight integer,
    supports_contractor boolean,
    impact_score integer,
    created_at timestamp with time zone DEFAULT now() NOT NULL
);

--
-- Name: pcos_analysis_runs; Type: TABLE
--

CREATE TABLE public.pcos_analysis_runs (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    tenant_id uuid NOT NULL,
    run_type character varying(50) NOT NULL,
    run_status character varying(20) DEFAULT 'pending'::character varying NOT NULL,
    project_id uuid,
    entity_type character varying(50),
    entity_id uuid,
    run_parameters jsonb DEFAULT '{}'::jsonb NOT NULL,
    rule_pack_version character varying(50),
    fact_snapshot_time timestamp with time zone DEFAULT now() NOT NULL,
    total_evaluations integer DEFAULT 0,
    pass_count integer DEFAULT 0,
    fail_count integer DEFAULT 0,
    warning_count integer DEFAULT 0,
    indeterminate_count integer DEFAULT 0,
    started_at timestamp with time zone,
    completed_at timestamp with time zone,
    execution_time_ms integer,
    error_message text,
    created_at timestamp with time zone DEFAULT now() NOT NULL
);

--
-- Name: pcos_audit_events; Type: TABLE
--

CREATE TABLE public.pcos_audit_events (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    tenant_id uuid NOT NULL,
    project_id uuid,
    event_type character varying(100) NOT NULL,
    event_action character varying(100) NOT NULL,
    actor_id uuid,
    actor_email character varying(255),
    actor_role character varying(100),
    entity_type character varying(50),
    entity_id uuid,
    event_data jsonb DEFAULT '{}'::jsonb NOT NULL,
    previous_state jsonb,
    new_state jsonb,
    ip_address character varying(45),
    user_agent text,
    request_id character varying(100),
    created_at timestamp with time zone DEFAULT now() NOT NULL
);

--
-- Name: pcos_authority_documents; Type: TABLE
--

CREATE TABLE public.pcos_authority_documents (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    tenant_id uuid NOT NULL,
    document_type character varying(100) NOT NULL,
    jurisdiction character varying(100),
    authority_name character varying(255) NOT NULL,
    title text NOT NULL,
    citation character varying(500),
    effective_date date,
    expiration_date date,
    is_current boolean DEFAULT true NOT NULL,
    content_url character varying(500),
    content_hash character varying(64),
    content_format character varying(50),
    last_verified_at timestamp with time zone,
    verification_status character varying(50) DEFAULT 'unverified'::character varying,
    source_reliability_score integer,
    created_by uuid,
    updated_by uuid,
    version_number integer DEFAULT 1 NOT NULL,
    supersedes_document_id uuid,
    metadata jsonb DEFAULT '{}'::jsonb NOT NULL,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL
);

--
-- Name: pcos_budget_line_items; Type: TABLE
--

CREATE TABLE public.pcos_budget_line_items (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    budget_id uuid NOT NULL,
    tenant_id uuid NOT NULL,
    line_type character varying(50) NOT NULL,
    category character varying(100) NOT NULL,
    subcategory character varying(100),
    description text NOT NULL,
    amount_budgeted numeric(15,2) NOT NULL,
    amount_actual numeric(15,2) DEFAULT 0 NOT NULL,
    amount_variance numeric(15,2),
    variance_percentage numeric(5,2),
    is_qualified_spend boolean DEFAULT false,
    spend_category_id uuid,
    notes text,
    metadata jsonb DEFAULT '{}'::jsonb NOT NULL,
    sort_order integer,
    created_by uuid,
    updated_by uuid,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL
);

--
-- Name: pcos_budgets; Type: TABLE
--

CREATE TABLE public.pcos_budgets (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    tenant_id uuid NOT NULL,
    project_id uuid NOT NULL,
    budget_name character varying(255) NOT NULL,
    budget_version character varying(50) NOT NULL,
    budget_status character varying(50) DEFAULT 'draft'::character varying NOT NULL,
    currency_code character varying(3) DEFAULT 'USD'::character varying NOT NULL,
    total_budget numeric(15,2) NOT NULL,
    total_actual numeric(15,2) DEFAULT 0 NOT NULL,
    total_variance numeric(15,2),
    qualified_spend_total numeric(15,2) DEFAULT 0 NOT NULL,
    budget_start_date date NOT NULL,
    budget_end_date date NOT NULL,
    approved_by uuid,
    approved_at timestamp with time zone,
    is_locked boolean DEFAULT false NOT NULL,
    locked_by uuid,
    locked_at timestamp with time zone,
    notes text,
    metadata jsonb DEFAULT '{}'::jsonb NOT NULL,
    created_by uuid,
    updated_by uuid,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL
);

