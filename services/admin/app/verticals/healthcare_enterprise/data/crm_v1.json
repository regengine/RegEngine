{
    "id": "crm_v1",
    "name": "Clinical Risk Monitor v1.0",
    "version": "1.0.0",
    "description": "Enterprise-grade surveillance and risk monitoring for hospital systems.",
    "vertical": "healthcare_enterprise",
    "categories": [
        {
            "id": "behavioral_surveillance",
            "name": "Behavioral Surveillance",
            "rules": [
                {
                    "id": "SEC-01",
                    "name": "VIP Record Access",
                    "description": "Detects access to designated VIP patient records by unauthorized staff.",
                    "severity": "critical",
                    "monitor_type": "realtime"
                },
                {
                    "id": "SEC-02",
                    "name": "After-Hours Activity",
                    "description": "Flags record access occurring between 22:00 and 05:00 local time.",
                    "severity": "medium",
                    "monitor_type": "log_analysis"
                }
            ]
        },
        {
            "id": "access_governance",
            "name": "Access Governance",
            "rules": [
                {
                    "id": "GOV-01",
                    "name": "Role Mismatch",
                    "description": "Flags clinical actions performed by administrative accounts.",
                    "severity": "high",
                    "monitor_type": "access_review"
                },
                {
                    "id": "GOV-02",
                    "name": "Mass Export Detection",
                    "description": "Alerts on >50 record exports in <5 minutes.",
                    "severity": "critical",
                    "monitor_type": "realtime"
                }
            ]
        },
        {
            "id": "audit_integrity",
            "name": "Audit Integrity",
            "rules": [
                {
                    "id": "AUDIT-01",
                    "name": "Gap Detection",
                    "description": "Identifies missing sequence numbers in access logs.",
                    "severity": "high",
                    "monitor_type": "integrity_check"
                }
            ]
        }
    ]
}