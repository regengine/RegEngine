{
    "rule_pack_id": "healthcare_hipaa_v1",
    "title": "Healthcare: Patient Privacy & Clinical Safety",
    "version": "1.0",
    "frameworks": [
        "HIPAA",
        "HITECH",
        "FDA 21 CFR Part 11"
    ],
    "rules": [
        {
            "rule_id": "HIPAA-ADM-01",
            "domain": "Administrative",
            "requirement": "Risk Management Process",
            "checklist_item": "Conduct thorough assessments of potential vulnerabilities to ePHI; implement measures to reduce risk to reasonable levels.",
            "severity": "CRITICAL",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-ADM-02",
            "domain": "Administrative",
            "requirement": "Assigned Responsibility",
            "checklist_item": "Designate a Security Officer to lead the development and implementation of all privacy and security policies.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-ADM-03",
            "domain": "Administrative",
            "requirement": "Workforce Security",
            "checklist_item": "Establish policies for authorizing access to ePHI based on the 'minimum necessary' standard; implement termination protocols.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-ADM-04",
            "domain": "Administrative",
            "requirement": "Contingency Planning",
            "checklist_item": "Create disaster recovery and business continuity plans; ensure redundant, encrypted backups are stored off-site.",
            "severity": "CRITICAL",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-PHY-01",
            "domain": "Physical",
            "requirement": "Facility Access Controls",
            "checklist_item": "Use locks, alarms, ID badges, and cameras to restrict entry to server rooms and offices where PHI is accessible.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-PHY-02",
            "domain": "Physical",
            "requirement": "Workstation Security",
            "checklist_item": "Position monitors to prevent visual exposure; implement automatic screen locking and privacy filters.",
            "severity": "MEDIUM",
            "evidence_required": false
        },
        {
            "rule_id": "HIPAA-PHY-03",
            "domain": "Physical",
            "requirement": "Device/Media Controls",
            "checklist_item": "Maintain an inventory of hardware; implement procedures for the secure disposal or re-use of electronic media containing PHI.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-TECH-01",
            "domain": "Technical",
            "requirement": "Access Control",
            "checklist_item": "Assign unique user IDs; enforce strong passwords and MFA; implement automatic session logoffs for inactivity.",
            "severity": "CRITICAL",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-TECH-02",
            "domain": "Technical",
            "requirement": "Audit Controls",
            "checklist_item": "Deploy hardware and software to record and examine all activity within systems that store or use ePHI.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-TECH-03",
            "domain": "Technical",
            "requirement": "Integrity Measures",
            "checklist_item": "Implement electronic mechanisms (e.g., checksums) to confirm that ePHI has not been improperly altered or destroyed.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "HIPAA-TECH-04",
            "domain": "Technical",
            "requirement": "Transmission Security",
            "checklist_item": "Ensure end-to-end encryption for all PHI transmitted over networks, including emails and secure messaging apps.",
            "severity": "CRITICAL",
            "evidence_required": true
        }
    ]
}