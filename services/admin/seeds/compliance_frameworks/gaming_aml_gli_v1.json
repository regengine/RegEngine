{
    "rule_pack_id": "gaming_aml_gli_v1",
    "title": "Gaming: Fairness & Anti-Financial Crime",
    "version": "1.0",
    "frameworks": [
        "AML/KYC",
        "GLI-11",
        "GLI-19"
    ],
    "rules": [
        {
            "rule_id": "GAM-KYC-01",
            "domain": "AML/KYC",
            "requirement": "Customer Due Diligence",
            "checklist_item": "Collect name, DOB, and address; verify ID with liveness detection; screen for Politically Exposed Persons (PEPs).",
            "severity": "CRITICAL",
            "evidence_required": true
        },
        {
            "rule_id": "GAM-AML-01",
            "domain": "AML/KYC",
            "requirement": "Transaction Monitoring",
            "checklist_item": "Use AI to track large cash deposits, rapid chip cashouts, and 'chip dumping'; file SARs for suspicious activity.",
            "severity": "CRITICAL",
            "evidence_required": true
        },
        {
            "rule_id": "GAM-REC-01",
            "domain": "AML/KYC",
            "requirement": "Record Keeping",
            "checklist_item": "Maintain identification records and transaction logs for at least five to seven years for auditability.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "GLI-RNG-01",
            "domain": "GLI-11/GLI-19",
            "requirement": "RNG Certification",
            "checklist_item": "Verify that the Random Number Generator is statistically independent, uniform in distribution, and unpredictable.",
            "severity": "CRITICAL",
            "evidence_required": true
        },
        {
            "rule_id": "GLI-SEC-01",
            "domain": "GLI-11/GLI-19",
            "requirement": "Machine Security",
            "checklist_item": "Ensure logic areas are locked and keyed differently; implement sensors to detect and log every door opening.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "GLI-DAT-01",
            "domain": "GLI-11/GLI-19",
            "requirement": "Critical Data Recovery",
            "checklist_item": "Protect meters and game state in non-volatile RAM; ensure system can recover play after power loss or surges.",
            "severity": "HIGH",
            "evidence_required": true
        },
        {
            "rule_id": "GLI-DIS-01",
            "domain": "GLI-11/GLI-19",
            "requirement": "Fair Display",
            "checklist_item": "Clearly display paytables, game rules, and return-to-player (RTP) percentages; indicate that malfunctions void all pays.",
            "severity": "MEDIUM",
            "evidence_required": false
        },
        {
            "rule_id": "GAM-RES-01",
            "domain": "Responsible Gaming",
            "requirement": "Player Protection",
            "checklist_item": "Implement deposit limits, time-based restrictions, and integration with state self-exclusion databases.",
            "severity": "HIGH",
            "evidence_required": true
        }
    ]
}