# Normalize line endings to LF on checkout
* text=auto eol=lf

# Explicit text files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf
*.toml text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Lock files — don't diff
package-lock.json -diff
