+function complianceLabel(score: number | null): { color: string; bg: string; label: string; icon: typeof CheckCircle2 } {
+    if (score === null) return { color: '#6b7280', bg: 'rgba(107,114,128,0.08)', label: 'No Data', icon: Clock };
