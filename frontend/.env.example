# RegEngine Frontend — Vercel Environment Variables
# Copy to .env.local for local development.
# On Vercel: Settings → Environment Variables (set for Production + Preview).

# ── CRITICAL: Auth JWT Secret ───────────────────────────────
# MUST match the backend AUTH_SECRET_KEY exactly.
# Backend signs tokens with this; middleware.ts verifies with this.
# Mismatch = login redirect loop (?error=session_expired).
AUTH_SECRET_KEY=

# ── Backend Service URLs ────────────────────────────────────
# Used by /api/admin proxy to reach the Railway admin service.
# Without this, the proxy falls back to http://localhost:8400 and 502s.
NEXT_PUBLIC_ADMIN_URL=https://admin-api-production.up.railway.app

# Server-side alternative (not exposed to browser):
# ADMIN_SERVICE_URL=https://admin-api-production.up.railway.app

# ── Supabase (fallback auth) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Optional ────────────────────────────────────────────────
# NEXT_PUBLIC_API_KEY=           # Default API key for unauthenticated requests
# NEXT_PUBLIC_API_BASE_URL=      # Unified gateway URL (if using nginx proxy)
# NEXT_PUBLIC_INGESTION_URL=     # Override ingestion service URL
# NEXT_PUBLIC_GRAPH_URL=         # Override graph service URL
# NEXT_PUBLIC_COMPLIANCE_URL=    # Override compliance service URL
# NEXT_PUBLIC_NLP_URL=           # Override NLP service URL
