{
    "version": 2,
    "public": true,
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "framework": "nextjs",
    "outputDirectory": ".next",
    "regions": [
        "sfo1"
    ],
    "functions": {
        "src/app/api/admin/[...path]/route.ts": {
            "maxDuration": 300
        },
        "src/app/api/ingestion/[...path]/route.ts": {
            "maxDuration": 60
        },
        "src/app/api/compliance/[...path]/route.ts": {
            "maxDuration": 60
        }
    },
    "env": {
        "REGENGINE_DEPLOY_MODE": "cloud",
        "INGESTION_SERVICE_URL": "@ingestion-service-url",
        "COMPLIANCE_SERVICE_URL": "@compliance-service-url",
        "ADMIN_SERVICE_URL": "@admin-service-url"
    }
}